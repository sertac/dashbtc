# Environment Variables Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5007

# Symbol Configuration
DEFAULT_SYMBOL=ETH/USDT
TIMEFRAME=5m

# Database
# SQLite (local): sqlite:///signals.db
# PostgreSQL (Render/Neon): postgres://user:pass@ep-xxx.aws.neon.tech/botdb
DATABASE_URL=sqlite:///signals.db

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
TELEGRAM_WINRATE_INTERVAL=3600

# API Keys (if needed for future features)
BINANCE_API_KEY=your-api-key-here
BINANCE_SECRET_KEY=your-secret-key-here
